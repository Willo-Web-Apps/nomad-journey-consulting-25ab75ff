---
import Base from '../layouts/Base.astro';
---

<Base
  title="Roamly — Live and work from anywhere, sustainably"
  description="Roamly is a boutique consulting firm helping aspiring digital nomads build a balanced, sustainable remote life with a real plan, not just inspiration."
>

  <!-- ═══════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════ -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">
    <!-- Layered CSS background -->
    <div class="absolute inset-0" style="background:
      radial-gradient(ellipse at 15% 60%, oklch(0.58 0.16 38 / 0.12), transparent 55%),
      radial-gradient(ellipse at 85% 20%, oklch(0.44 0.10 185 / 0.10), transparent 50%),
      radial-gradient(ellipse at 60% 90%, oklch(0.68 0.14 38 / 0.07), transparent 45%),
      linear-gradient(160deg, oklch(0.985 0.008 80) 0%, oklch(0.96 0.012 80) 100%);"></div>

    <!-- Decorative ring -->
    <div class="absolute right-[-160px] top-[-160px] w-[600px] h-[600px] rounded-full border border-brand-500/10 opacity-60"></div>
    <div class="absolute right-[-80px] top-[-80px] w-[420px] h-[420px] rounded-full border border-accent-500/10 opacity-40"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <p class="inline-flex items-center gap-2 text-sm font-semibold tracking-widest uppercase text-accent-500 mb-6 animate-slide-up">
          <span class="w-6 h-px bg-accent-500"></span>
          Boutique Nomad Consulting
        </p>

        <!-- H1 -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-surface-900 font-display leading-[1.05] animate-slide-up delay-100">
          Your roadmap to<br />
          <em class="italic font-light text-brand-500 not-italic" style="font-style:italic;">a life lived</em><br />
          on your terms
        </h1>

        <!-- Sub -->
        <p class="mt-8 text-lg md:text-xl text-surface-800/70 max-w-xl leading-relaxed animate-slide-up delay-200">
          Roamly helps aspiring nomads cut through the overwhelm and build a balanced, sustainable remote life — with a real plan, not just inspiration.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-slide-up delay-300">
          <a href="#cta" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-500 text-white font-semibold rounded-xl hover:bg-brand-600 transition-colors text-base">
            Book my free clarity call
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/></svg>
          </a>
          <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-surface-200 text-surface-900 font-semibold rounded-xl hover:border-brand-500 hover:text-brand-500 transition-colors text-base bg-white/60 backdrop-blur-sm">
            See how it works
          </a>
        </div>

        <!-- Micro-proof -->
        <p class="mt-5 text-sm text-surface-800/50 animate-slide-up delay-400">
          Free 30-minute call · No pitch, just clarity · Results in weeks, not years
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       SOCIAL PROOF BAR
       ═══════════════════════════════════════════════════ -->
  <section class="bg-brand-500 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="animate-fade-in">
          <p class="text-3xl font-extrabold text-white font-display">200+</p>
          <p class="mt-1 text-sm text-white/70 font-medium">Nomads guided</p>
        </div>
        <div class="animate-fade-in delay-100">
          <p class="text-3xl font-extrabold text-white font-display">40+</p>
          <p class="mt-1 text-sm text-white/70 font-medium">Countries covered</p>
        </div>
        <div class="animate-fade-in delay-200">
          <p class="text-3xl font-extrabold text-white font-display">4 hrs</p>
          <p class="mt-1 text-sm text-white/70 font-medium">Owner time per week</p>
        </div>
        <div class="animate-fade-in delay-300">
          <p class="text-3xl font-extrabold text-white font-display">93%</p>
          <p class="mt-1 text-sm text-white/70 font-medium">Still nomadic at 12 months</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       POSITIONING / WHO IT'S FOR
       ═══════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 lg:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <!-- Left: text -->
        <div>
          <p class="inline-flex items-center gap-2 text-sm font-semibold tracking-widest uppercase text-accent-500 mb-5 animate-slide-up">
            <span class="w-6 h-px bg-accent-500"></span>
            Who Roamly is for
          </p>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-surface-900 font-display leading-tight animate-slide-up delay-100">
            You've done the research.<br />
            <span class="text-brand-500 italic" style="font-style:italic;">Now do it for real.</span>
          </h2>
          <p class="mt-6 text-lg text-surface-800/70 leading-relaxed animate-slide-up delay-200">
            You've read every blog, watched every YouTube channel, and still feel stuck. The visa rules conflict. The tax advice is confusing. You don't know which country actually fits your life.
          </p>
          <p class="mt-4 text-lg text-surface-800/70 leading-relaxed animate-slide-up delay-300">
            Roamly gives professionals and freelancers aged 25–42 a structured, honest path to location independence — built around your income, your work, and the lifestyle you actually want.
          </p>
          <ul class="mt-8 space-y-3 animate-slide-up delay-400">
            {[
              'Employed professional planning your exit',
              'Freelancer ready to work from anywhere',
              'Early-stage nomad struggling with burnout or inconsistent income',
            ].map((item) => (
              <li class="flex items-start gap-3 text-surface-800/80">
                <svg class="w-5 h-5 mt-0.5 text-brand-500 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: pull-quote card -->
        <div class="relative animate-fade-in delay-200">
          <div class="absolute -top-4 -left-4 w-full h-full rounded-2xl bg-accent-500/10 border border-accent-500/20"></div>
          <div class="relative rounded-2xl bg-white border border-surface-200 p-10 shadow-sm">
            <svg class="w-10 h-10 text-accent-500 mb-6" fill="currentColor" viewBox="0 0 32 32">
              <path d="M10 8C6.686 8 4 10.686 4 14s2.686 6 6 6c.36 0 .708-.034 1.048-.096C10.36 21.402 9.22 23.09 7.5 24.5L9 26c3.14-2.48 5-6.3 5-10 0-4.418-1.79-8-4-8zm14 0c-3.314 0-6 2.686-6 6s2.686 6 6 6c.36 0 .708-.034 1.048-.096C24.36 21.402 23.22 23.09 21.5 24.5L23 26c3.14-2.48 5-6.3 5-10 0-4.418-1.79-8-4-8z"/>
            </svg>
            <p class="text-xl font-light text-surface-900 leading-relaxed font-display italic">
              "I'd been 'planning' to go nomad for two years. After one session with Roamly, I had an actual timeline, a visa strategy, and a client structure that let me work 25 hours a week from Lisbon."
            </p>
            <div class="mt-8 flex items-center gap-4">
              <div class="w-11 h-11 rounded-full bg-brand-100 flex items-center justify-center text-brand-500 font-bold font-display text-lg">S</div>
              <div>
                <p class="font-semibold text-surface-900">Sophie R.</p>
                <p class="text-sm text-surface-800/50">UX Designer → Lisbon, Portugal</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       FEATURES / WHAT YOU GET
       ═══════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 lg:py-32 bg-surface-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="inline-flex items-center gap-2 text-sm font-semibold tracking-widest uppercase text-accent-500 mb-5 animate-slide-up">
          <span class="w-6 h-px bg-accent-500"></span>
          What you get
        </p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-surface-900 font-display leading-tight animate-slide-up delay-100">
          Everything you need to make the leap — nothing you don't
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="bg-white rounded-2xl p-8 border border-surface-200 hover:border-brand-400 transition-colors group animate-slide-up">
          <div class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center mb-6 group-hover:bg-brand-100 transition-colors">
            <svg class="w-6 h-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Your Custom Nomad Blueprint</h3>
          <p class="text-surface-800/70 leading-relaxed">A personalised roadmap covering country selection, visa pathways, tax residency, income structure, and a week-by-week launch plan built for your specific life.</p>
        </div>

        <!-- Card 2 -->
        <div class="bg-white rounded-2xl p-8 border border-surface-200 hover:border-brand-400 transition-colors group animate-slide-up delay-100">
          <div class="w-12 h-12 rounded-xl bg-accent-500/10 flex items-center justify-center mb-6 group-hover:bg-accent-500/20 transition-colors">
            <svg class="w-6 h-6 text-accent-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Sustainable Income Design</h3>
          <p class="text-surface-800/70 leading-relaxed">We'll structure your freelance or remote work so it covers your costs, gives you free time, and doesn't burn you out — whether you're billing 20 hours or 40.</p>
        </div>

        <!-- Card 3 -->
        <div class="bg-white rounded-2xl p-8 border border-surface-200 hover:border-brand-400 transition-colors group animate-slide-up delay-200">
          <div class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center mb-6 group-hover:bg-brand-100 transition-colors">
            <svg class="w-6 h-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Country & Visa Intelligence</h3>
          <p class="text-surface-800/70 leading-relaxed">Cut through contradictory advice online. We give you clear, up-to-date guidance on digital nomad visas, tax treaties, and where to go first based on your situation.</p>
        </div>

        <!-- Card 4 -->
        <div class="bg-white rounded-2xl p-8 border border-surface-200 hover:border-brand-400 transition-colors group animate-slide-up delay-300">
          <div class="w-12 h-12 rounded-xl bg-accent-500/10 flex items-center justify-center mb-6 group-hover:bg-accent-500/20 transition-colors">
            <svg class="w-6 h-6 text-accent-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Community & Ongoing Support</h3>
          <p class="text-surface-800/70 leading-relaxed">Loneliness is the silent killer of nomad life. Roamly connects you with a vetted peer group and gives you direct access to guidance as your situation evolves.</p>
        </div>

        <!-- Card 5 -->
        <div class="bg-white rounded-2xl p-8 border border-surface-200 hover:border-brand-400 transition-colors group animate-slide-up delay-400">
          <div class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center mb-6 group-hover:bg-brand-100 transition-colors">
            <svg class="w-6 h-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Priced for Real People</h3>
          <p class="text-surface-800/70 leading-relaxed">Not $28,000 offshore tax schemes. Roamly's packages are designed for professionals making a genuine transition — straightforward pricing, real outcomes.</p>
        </div>

        <!-- Card 6 -->
        <div class="bg-brand-500 rounded-2xl p-8 animate-slide-up delay-500">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white font-display mb-3">Frameworks That Actually Work</h3>
          <p class="text-white/80 leading-relaxed">Roamly's structured consulting approach — not generic listicles — gives you the clarity to act. Our clients move from overwhelm to action in under 30 days.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       HOW IT WORKS
       ═══════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-20 md:py-28 lg:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="inline-flex items-center gap-2 text-sm font-semibold tracking-widest uppercase text-accent-500 mb-5 animate-slide-up">
          <span class="w-6 h-px bg-accent-500"></span>
          How it works
        </p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-surface-900 font-display leading-tight animate-slide-up delay-100">
          From overwhelmed to on the plane — in three steps
        </h2>
      </div>

      <div class="relative">
        <!-- Connector line (desktop) -->
        <div class="hidden md:block absolute top-12 left-[calc(16.67%+24px)] right-[calc(16.67%+24px)] h-px bg-surface-200"></div>

        <div class="grid md:grid-cols-3 gap-12 md:gap-8">
          <!-- Step 1 -->
          <div class="flex flex-col items-center text-center animate-slide-up">
            <div class="relative w-24 h-24 rounded-full bg-white border-2 border-brand-500 flex items-center justify-center mb-8 shrink-0 shadow-sm">
              <span class="text-3xl font-black text-brand-500 font-display">1</span>
            </div>
            <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Free Clarity Call</h3>
            <p class="text-surface-800/70 leading-relaxed">30 minutes with a Roamly advisor. We figure out where you are, where you want to go, and whether we're a fit. No sales pressure.</p>
          </div>

          <!-- Step 2 -->
          <div class="flex flex-col items-center text-center animate-slide-up delay-200">
            <div class="relative w-24 h-24 rounded-full bg-brand-500 flex items-center justify-center mb-8 shrink-0 shadow-sm">
              <span class="text-3xl font-black text-white font-display">2</span>
            </div>
            <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Get Your Blueprint</h3>
            <p class="text-surface-800/70 leading-relaxed">We build your custom nomad roadmap — visa strategy, income structure, country shortlist, timeline, and a week-by-week action plan tailored to you.</p>
          </div>

          <!-- Step 3 -->
          <div class="flex flex-col items-center text-center animate-slide-up delay-400">
            <div class="relative w-24 h-24 rounded-full bg-white border-2 border-accent-500 flex items-center justify-center mb-8 shrink-0 shadow-sm">
              <span class="text-3xl font-black text-accent-500 font-display">3</span>
            </div>
            <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Live the Life</h3>
            <p class="text-surface-800/70 leading-relaxed">Execute with confidence. Roamly stays with you — answering questions, adjusting your plan, and connecting you with a community of nomads who get it.</p>
          </div>
        </div>
      </div>

      <!-- Secondary testimonial -->
      <div class="mt-20 max-w-2xl mx-auto bg-surface-100 border border-surface-200 rounded-2xl p-8 text-center animate-fade-in delay-300">
        <p class="text-lg font-light text-surface-900 leading-relaxed font-display italic">
          "I spent six months Googling myself in circles. Two weeks with Roamly and I had a signed lease in Medellín and a tax setup that saved me €4,200 that first year."
        </p>
        <div class="mt-6 flex items-center justify-center gap-3">
          <div class="w-10 h-10 rounded-full bg-accent-500/20 flex items-center justify-center text-accent-500 font-bold font-display">M</div>
          <div class="text-left">
            <p class="font-semibold text-surface-900 text-sm">Marcus T.</p>
            <p class="text-xs text-surface-800/50">Software Engineer → Medellín, Colombia</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       PRICING TEASER
       ═══════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-surface-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="inline-flex items-center gap-2 text-sm font-semibold tracking-widest uppercase text-accent-500 mb-5 animate-slide-up">
          <span class="w-6 h-px bg-accent-500"></span>
          Simple, honest pricing
        </p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-surface-900 font-display leading-tight animate-slide-up delay-100">
          Real guidance at a real price
        </h2>
        <p class="mt-4 text-lg text-surface-800/60 animate-slide-up delay-200">Not $28k offshore schemes. Not free blog posts that leave you more confused.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <!-- Starter -->
        <div class="bg-white rounded-2xl p-8 border border-surface-200 animate-slide-up">
          <p class="text-sm font-semibold text-surface-800/50 tracking-wide uppercase mb-2">Starter</p>
          <p class="text-4xl font-extrabold text-surface-900 font-display">$297</p>
          <p class="text-sm text-surface-800/50 mt-1">one-time</p>
          <ul class="mt-8 space-y-3">
            {[
              '60-min strategy session',
              'Country & visa shortlist',
              'Income structure audit',
              'Recorded for replay',
            ].map((f) => (
              <li class="flex items-center gap-3 text-sm text-surface-800/80">
