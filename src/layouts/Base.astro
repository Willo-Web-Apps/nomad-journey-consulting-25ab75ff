---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Roamly — Live and work from anywhere, sustainably",
  description = "Roamly is a boutique consulting firm helping aspiring digital nomads build a balanced, sustainable remote life — with a real plan, not just inspiration."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Roamly",
      "description": "Boutique consulting firm for aspiring and early-stage digital nomads who want to build a sustainable, balanced nomadic lifestyle.",
      "url": "https://roamly.onrender.com",
      "email": "hello@roamly.co",
      "keywords": "digital nomad consulting, nomad lifestyle coaching, remote work abroad, sustainable nomad life, location independence"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
